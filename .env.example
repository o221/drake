# MSSQL connection — read by the Vite dev-server plugin (Node.js only).
# These vars are NOT exposed to the browser bundle (no VITE_ prefix).
# Copy this file to .env and fill in the real values.

MSSQL_HOST=sql-server-host
MSSQL_PORT=sql-server-port # Optional, defaults to 1433
MSSQL_DATABASE=sql-database-name
MSSQL_USER=sql-username
MSSQL_PASSWORD=sql-password
MSSQL_SCHEMA=sql-schema-name # Optional, defaults to 'dbo'
MSSQL_ATTACH_ALIAS=sql-attach-alias
